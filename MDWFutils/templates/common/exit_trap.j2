# Job status tracking
_SIG=""; trap '_SIG=1' TERM INT
_update_status() {
    local ec=$? st="" state=""
    # Signal caught or signal exit codes (130=INT, 137=KILL, 143=TERM)
    [ -n "$_SIG" ] || case $ec in 130|137|143) _SIG=1;; esac
    # Query SLURM state
    [ -n "$SLURM_JOB_ID" ] && { sleep 1; state=$(sacct -X -j $SLURM_JOB_ID -n -o State --parsable2 2>/dev/null | head -1); }
    # Determine status
    case "$(echo "$state" | tr a-z A-Z)" in *CANCEL*|*PREEMPT*) st="CANCELED";; *TIMEOUT*) st="TIMEOUT";; *FAIL*) st="FAILED";; esac
    [ -z "$st" ] && [ -n "$_SIG" ] && st="CANCELED"
    [ -z "$st" ] && { [ $ec -eq 0 ] && st="COMPLETED" || st="FAILED"; }
    mdwf_db update -e {{ ensemble_id }} -o {{ operation_type | default(operation) }} -s $st \
        -p "slurm_job_id=$SLURM_JOB_ID exit_code=$ec runtime=$SECONDS host=$(hostname) slurm_state=${state:-unknown}" || true
}
trap _update_status EXIT